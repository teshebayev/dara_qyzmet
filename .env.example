# Скопируйте в .env (необязательно — у всех значений есть дефолты)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dara
JWT_SECRET=dev-secret-change-me

# VLM: true = заглушка без GPU (по умолчанию); false = реальный vLLM (профиль gpu)
MOCK_VLM=true
# Для реального инференса:
# VLLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
# GPU_DEVICE=0
# HF_CACHE_DIR=~/.cache/huggingface
