# Скопируйте в .env (необязательно — у всех значений есть дефолты)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dara
JWT_SECRET=dev-secret-change-me

# Qdrant (поиск товара по каталогу для агента; CLIP-эмбеддинги, CPU/ONNX)
QDRANT_URL=http://qdrant:6333

# Telegram-бот приёмки (опционально). Токен от @BotFather. Запуск:
#   docker compose --profile bot up -d bot
# BOT_TOKEN=123456:ABC-DEF...
# Mini App с реалтайм-камерой (брак/излишек): публичный HTTPS-URL туннеля к api
# (напр. ngrok http 8080). Пусто -> бот просит прислать фото обычным сообщением.
# BOT_PUBLIC_URL=https://xxxx.ngrok-free.app

# Langfuse (трассировка агента). По умолчанию — локальный self-hosted сервис из
# docker-compose (ключи pk-lf-dara-local / sk-lf-dara-local, UI на :3001, логин
# admin@dara.local / darademo123). Чтобы выключить — задайте пустые ключи.
# Для Langfuse Cloud — свои ключи и host:
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# vLLM (Qwen2.5-VL) — поднимается отдельно через ./run_vllm.sh, нужен GPU.
# Приложение ходит к нему по OpenAI-совместимому API:
# OPENAI_BASE_URL=http://host.docker.internal:8000/v1
# VLM_MODEL=qwen
# LLM_MODEL=qwen
# Параметры самого vLLM (см. run_vllm.sh):
# VLLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
# GPU_DEVICE=0
# HF_CACHE_DIR=~/.cache/huggingface
